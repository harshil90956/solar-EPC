# # Google Maps API Key for Solar Design Studio
# # Get your key from: https://console.cloud.google.com/google/maps-apis
# # Required libraries: drawing, geometry, places
# REACT_APP_GOOGLE_MAPS_API_KEY=YOUR_API_KEY_HERE

# # Suppress webpack source map warnings from node_modules
# GENERATE_SOURCEMAP=false