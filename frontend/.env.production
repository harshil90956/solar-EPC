# REACT_APP_COMPANY=SolarCorp India Pvt. Ltd.
# REACT_APP_DEFAULT_PAGE_SIZE=20
# REACT_APP_MAX_PAGE_SIZE=100
# REACT_APP_ENABLE_MOCK=true
